

RewriteEngine On
# Producción (Docker / EasyPanel en raíz del dominio):
RewriteBase /
# Instalación local en subcarpeta: comenta la línea anterior y descomenta:
# RewriteBase /ventacodigorestaurante/

RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-l

RewriteRule ^(.+)$ index.php?url=$1 [QSA,L]

#en caso sea una instalacion local comentar estas lineas con #
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]